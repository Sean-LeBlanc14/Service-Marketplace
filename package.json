{
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.3.29",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3"
  },
  "workspaces": [
    "packages/frontend"
  ],
  "scripts": {
